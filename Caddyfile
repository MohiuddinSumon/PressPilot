# PressPilot Caddyfile
# Caddy handles automatic Let's Encrypt SSL for all domains.
# Cloudflare must be set to SSL mode "Full (strict)".
# After adding a new domain, run: docker compose exec caddy caddy reload --config /etc/caddy/Caddyfile

# ---------------------------------------------------------------------------
# Ghost — mostlyprompt.com
# ---------------------------------------------------------------------------
mostlyprompt.com, www.mostlyprompt.com {
    reverse_proxy ghost-mostlyprompt:2368
}

# ---------------------------------------------------------------------------
# Ghost — fellowcoder.com
# ---------------------------------------------------------------------------
fellowcoder.com, www.fellowcoder.com {
    reverse_proxy ghost-fellowcoder:2368
}

