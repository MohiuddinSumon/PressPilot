# PressPilot Environment Variables
# Copy this file to .env and fill in all values before running docker compose up
# Never commit .env to git

# =============================================================================
# GENERAL
# =============================================================================

# Your Oracle VM's public IP address
ORACLE_VM_IP=

# =============================================================================
# MYSQL (shared by all Ghost instances)
# =============================================================================

MYSQL_ROOT_PASSWORD=change_me_strong_password
MYSQL_USER=ghost
MYSQL_PASSWORD=change_me_ghost_password

# =============================================================================
# GHOST — mostlyprompt.com (Priority 1)
# =============================================================================

GHOST_MOSTLYPROMPT_URL=https://mostlyprompt.com
GHOST_MOSTLYPROMPT_DB_NAME=ghost_mostlyprompt
# Get from: Ghost Admin → Settings → Integrations → Add custom integration
GHOST_MOSTLYPROMPT_ADMIN_API_KEY=

# =============================================================================
# GHOST — fellowcoder.com
# =============================================================================

GHOST_FELLOWCODER_URL=https://fellowcoder.com
GHOST_FELLOWCODER_DB_NAME=ghost_fellowcoder
GHOST_FELLOWCODER_ADMIN_API_KEY=

# =============================================================================
# GHOST — aimovi.com (if running as Ghost)
# =============================================================================

GHOST_AIMOVI_URL=https://aimovi.com
GHOST_AIMOVI_DB_NAME=ghost_aimovi
GHOST_AIMOVI_ADMIN_API_KEY=

# =============================================================================
# GHOST MAIL (Mailgun — shared SMTP, same for all Ghost instances)
# =============================================================================
# Sign up at mailgun.com, verify your domain, get SMTP credentials
# Free tier: 1,000 emails/month

GHOST_MAIL_TRANSPORT=SMTP
GHOST_MAIL_HOST=smtp.mailgun.org
GHOST_MAIL_PORT=587
GHOST_MAIL_USER=postmaster@mg.yourdomain.com
GHOST_MAIL_PASSWORD=your_mailgun_smtp_password
GHOST_MAIL_FROM=noreply@mostlyprompt.com

# =============================================================================
# n8n
# =============================================================================

# Basic auth for n8n web UI (set strong credentials)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_n8n_password

# n8n will be accessible at this URL via Caddy
N8N_HOST=n8n.mostlyprompt.com
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.mostlyprompt.com/

# n8n encryption key for stored credentials (generate: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=

# =============================================================================
# TELEGRAM (for notifications)
# =============================================================================
# Create bot via @BotFather in Telegram, get token
# Find chat ID: send /start to @userinfobot

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================================================
# LLM PROVIDERS
# Add keys for whichever providers you have. System degrades gracefully.
# =============================================================================

# Anthropic — console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI — platform.openai.com
OPENAI_API_KEY=

# xAI/Grok — console.x.ai
XAI_API_KEY=

# Google Gemini — aistudio.google.com
GEMINI_API_KEY=

# Ollama (self-hosted on same VM) — leave blank if not using
OLLAMA_URL=http://ollama:11434

# =============================================================================
# PROVIDER LAYER ROUTING CONFIG
# Controls which model handles which task tier
# =============================================================================

# Task routing: comma-separated provider priority list per tier
# Providers: anthropic, openai, xai, gemini, ollama
PROVIDER_SCORING=ollama,gemini,anthropic        # cheapest tier for keyword scoring
PROVIDER_RESEARCH=gemini,anthropic,openai       # mid tier for research summarization
PROVIDER_DRAFT=anthropic,openai,xai             # strongest tier for final post draft

# Model overrides (optional — provider layer picks sensible defaults if blank)
MODEL_ANTHROPIC_SCORING=claude-haiku-4-5-20251001
MODEL_ANTHROPIC_DRAFT=claude-sonnet-4-6
MODEL_OPENAI_SCORING=gpt-4o-mini
MODEL_OPENAI_DRAFT=gpt-4o
MODEL_GEMINI_SCORING=gemini-2.0-flash
MODEL_GEMINI_DRAFT=gemini-2.0-flash
MODEL_OLLAMA_SCORING=llama3.2

# =============================================================================
# KEYWORD STORE
# =============================================================================

# Option A: Google Sheets
# Service account JSON key (base64-encoded) — see docs/keyword-sheet.md
GOOGLE_SHEETS_CREDENTIALS_B64=
GOOGLE_SHEETS_SPREADSHEET_ID=

# Option B: NocoDB (self-hosted, preferred)
# Auto-configured if NocoDB container is running
NOCODB_AUTH_TOKEN=
NOCODB_API_URL=http://nocodb:8080

# =============================================================================
# NOCODB (keyword store — optional)
# =============================================================================

NOCODB_DB_PASSWORD=change_me_nocodb_password

# =============================================================================
# BACKUPS (Oracle Object Storage)
# =============================================================================

# Get from Oracle Cloud → Identity → Users → API Keys
OCI_NAMESPACE=
OCI_BUCKET_NAME=presspilot-backups
OCI_REGION=ap-singapore-1
OCI_ACCESS_KEY=
OCI_SECRET_KEY=
